# ============================================================
# PawGlobal — Environment Variables
# ============================================================
# For Vercel: Add these in the Vercel Dashboard → Project → Settings → Environment Variables
# For local development: Copy this file to .env and fill in the values
# ============================================================

# --- Database (REQUIRED) ---
# Get from Neon (https://neon.tech), Supabase, or any PostgreSQL provider
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# --- Stripe (REQUIRED for card payments) ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- SMTP Email (optional — for order/donation notifications) ---
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=hello@yourdomain.com
SMTP_PASSWORD=your_email_password_here
SMTP_FROM_NAME=PawGlobal
SMTP_FROM_EMAIL=hello@yourdomain.com

# ============================================================
# NOTE: Stripe keys and SMTP settings can also be configured
# directly through the Admin Panel → Settings after deployment.
# Values entered in the Admin Panel override these env vars.
# ============================================================
